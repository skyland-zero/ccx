<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.ccx.gateway</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/your-user/ccx/ccx-darwin-arm64</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/your-user/ccx</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PROXY_ACCESS_KEY</key>
      <string>your-proxy-access-key</string>
      <key>PORT</key>
      <string>3000</string>
      <key>ENABLE_WEB_UI</key>
      <string>true</string>
      <key>APP_UI_LANGUAGE</key>
      <string>zh-CN</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/your-user/ccx/logs/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/your-user/ccx/logs/stderr.log</string>
  </dict>
</plist>
